# =============================================================================
# Coto — Production Environment Variables
# =============================================================================
# Copy this file and fill in the values for your production deployment.
# NEVER commit the actual .env.production file to version control.

# === Backend (Cloud Run) ===

# App
ENVIRONMENT=production
DEBUG=false

# Database (Supabase PostgreSQL)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>?ssl=require
# Get this from: Supabase Dashboard > Settings > Database > Connection string (URI)
# Use the "Transaction mode" connection string for serverless (Cloud Run)
# IMPORTANT: Always include ?ssl=require for production
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?ssl=require

# Cache (Upstash Redis)
# Get this from: Upstash Console > Redis > Details > REST URL
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379

# OpenAI API
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# LLM models (optional — defaults shown)
LLM_CONVERSATION_MODEL=gpt-4.1-mini
LLM_CORRECTION_MODEL=gpt-4.1-mini

# TTS (optional — defaults shown)
TTS_VOICE=nova
TTS_MODEL=tts-1

# GCS (Google Cloud Storage — audio temporary buffering)
# Create bucket: gcloud storage buckets create gs://<your-bucket-name> --location=asia-northeast1
GCS_BUCKET_NAME=<your-bucket-name>
GCS_AUDIO_TTL_SECONDS=3600

# CORS
# Set to your mobile app's origin or Cloud Run URL if needed
CORS_ALLOWED_ORIGINS=["https://coyo-api-xxxxx-an.a.run.app"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=30

# === Frontend (EAS Build) ===

# Production API URL (your Cloud Run service URL)
API_BASE_URL=https://coyo-api-xxxxx-an.a.run.app
APP_ENV=production

# === GCP (for CI/CD and Cloud Run) ===

# GCP Project ID
GCP_PROJECT_ID=<your-project-id>
# Cloud Run service name
CLOUD_RUN_SERVICE=coyo-api
# Cloud Run region
CLOUD_RUN_REGION=asia-northeast1
# Artifact Registry repository
ARTIFACT_REGISTRY=asia-northeast1-docker.pkg.dev/<your-project-id>/coyo

# === Monitoring ===

# Sentry DSN (optional)
# Get this from: Sentry > Settings > Client Keys (DSN)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
