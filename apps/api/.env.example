# Local development (Docker Compose)
DATABASE_URL=postgresql+asyncpg://coyo:coyo_local@localhost:5432/coyo
REDIS_URL=redis://localhost:6379
OPENAI_API_KEY=
GCS_BUCKET_NAME=coyo-audio-dev
FIREBASE_PROJECT_ID=coyo-app-dev

# Firebase Admin SDK service account key (download from Firebase Console)
# See: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
