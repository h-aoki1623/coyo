{
  "name": "coto-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint src/",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/noto-sans-jp": "^0.4.3",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@react-native-community/netinfo": "^11.4.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "bignumber.js": "^9.1.2",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.0",
    "expo-dev-client": "~5.0.20",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-localization": "~16.0.1",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "i18n-js": "^4.5.2",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-safe-area-context": "4.14.1",
    "react-native-screens": "~4.5.0",
    "react-native-svg": "15.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "openapi-typescript": "^7.13.0",
    "patch-package": "^8.0.1",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|zustand)"
    ]
  }
}
